# Supabase connection — copy to .env.local and fill in.
# Found in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret (never exposed to the browser). Used by admin/server flows.
SUPABASE_SERVICE_ROLE_KEY=

# Local Supabase DB password (used by `supabase` CLI for local dev).
DB_PASS=
